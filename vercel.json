{
  "installCommand": "cd aurasense-ai && npm install",
  "buildCommand": "cd aurasense-ai && npm run build",
  "outputDirectory": "aurasense-ai/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://3.90.212.244:9000/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
